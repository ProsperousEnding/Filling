{
  "name": "vue-blog-framework",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "description": "一个基于 Vue 3 的静态博客框架",
  "author": "ProsperousEnding",
  "license": "MIT",
  "keywords": [
    "vue",
    "blog",
    "framework",
    "component",
    "vue3",
    "pinia",
    "tailwind"
  ],
  "files": [
    "dist"
  ],
  "main": "dist/vue-blog-framework.umd.js",
  "module": "dist/vue-blog-framework.es.js",
  "exports": {
    ".": {
      "import": "./dist/vue-blog-framework.es.js",
      "require": "./dist/vue-blog-framework.umd.js"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "build:content-index": "node scripts/build-content-index.mjs",
    "dev": "vite",
    "build": "vite build && node scripts/generate-static.mjs",
    "build:lib": "vite build --config vite.config.lib.js"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.4",
    "front-matter": "^4.0.2"
  },
  "peerDependencies": {
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/compiler-sfc": "^3.5.30",
    "autoprefixer": "^10.4.17",
    "markdown-it": "^14.1.0",
    "pinia": "^2.1.7",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "unplugin-vue-markdown": "^30.0.0",
    "vite": "7.1.5",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  }
}
